# PM Dashboard environment configuration
# Copy to .env and update values for your Supabase project

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# App URL — used as OAuth redirect destination after platform connection
APP_URL=https://your-app-url.com

# Meta (Instagram + Facebook) — App ID is public, safe in frontend build
META_APP_ID=your-meta-app-id-here

# LinkedIn OAuth — Client ID is public, safe in frontend build
LINKEDIN_CLIENT_ID=your-linkedin-client-id-here

# Google (YouTube) OAuth — Client ID is public, safe in frontend build
GOOGLE_CLIENT_ID=your-google-client-id-here
